# === Model Cache Patterns ===
# HuggingFace Hub uses specific cache patterns
models/**/snapshots/
models/**/refs/
models/**/*.index.json
models/**/*.bin
models/**/*.safetensors
models/**/model.safetensors
models/**/pytorch_model.bin
models/**/diffusion_pytorch_model.safetensors

# === Large Model Files (always generated locally) ===
# These are too large to commit - always generated on first use
models/huggingface/**
!models/huggingface/.gitkeep
!models/huggingface/.gitignore

# === Static Assets (User Generated) ===
static/assets/*
!static/assets/.gitkeep
static/data/*.json
!static/data/.gitkeep
static/config/*
!static/config/.gitkeep

# === Temporary Generation Files ===
temp_*
tmp_*
in_progress_*

# === Changelog (usually excluded from versioning for rapid updates) ===
